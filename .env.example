# === KONFIGURASI DATABASE POSTGRESQL ===
# Jangan isi dengan kredensial asli di sini! File ini hanya sebagai contoh (template).
# Copy file ini dan ubah namanya menjadi .env, lalu isi dengan data yang sebenarnya.

DB_USER=username_postgres_kamu
DB_PASS=password_postgres_kamu
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nama_database_kamu

